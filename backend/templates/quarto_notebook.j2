{# UNHCR Quarto Notebook Template #}
{# Uses Jinja2 templating for flexible document generation #}
---
title: {{ title|quote_yaml }}
author: {{ author|quote_yaml }}
date: {{ date|quote_yaml }}
format:
  html:
    embed-resources: true
    standalone: true
    format-links: false
    {%- if use_unhcr_theme %}
    theme:
      - unhcr
      - cosmo
    css: unhcr.css
    {%- else %}
    theme: cosmo
    {%- endif %}
  pdf:
    documentclass: article
    papersize: a4
    geometry:
      - top=30mm
      - left=20mm
      - right=20mm
      - bottom=30mm

{# Store all metadata in YAML header - ONLY visible in source file, NOT in rendered output #}
{%- if metadata %}
unhcr_metadata:
  {%- if metadata.get('audience') and metadata.audience is not none %}
  audience: {{ metadata.audience|quote_yaml }}
  {%- endif %}
  {%- if metadata.get('document_type') and metadata.document_type is not none %}
  document_type: {{ metadata.document_type|quote_yaml }}
  {%- endif %}
  {%- if metadata.get('analysis_config') and metadata.analysis_config is not none %}
  analysis_config: |
    {{ metadata.analysis_config|tojson|indent(4, first=false) }}
  {%- endif %}
  {%- if metadata.get('tool_sequence') and metadata.tool_sequence is not none %}
  tool_sequence: |
    {{ metadata.tool_sequence|tojson|indent(4, first=false) }}
  {%- endif %}
  {%- if metadata.get('statistics') and metadata.statistics is not none %}
  statistics: |
    {{ metadata.statistics|tojson|indent(4, first=false) }}
  {%- endif %}
  {%- if metadata.get('guardrails') and metadata.guardrails is not none %}
  guardrails: |
    {{ metadata.guardrails|tojson|indent(4, first=false) }}
  {%- endif %}
  {%- if metadata.get('visualization_structure') and metadata.visualization_structure is not none %}
  visualization_structure: |
    {{ metadata.visualization_structure|tojson|indent(4, first=false) }}
  {%- endif %}
  {%- if metadata.get('visualization_description') and metadata.visualization_description is not none %}
  visualization_description: |
    {{ metadata.visualization_description|tojson|indent(4, first=false) }}
  {%- endif %}
{% endif %}

{%- if original_query %}
original_query: {{ original_query|quote_yaml }}
{% endif %}

generated: {{ timestamp|quote_yaml }}
source: UNHCR Statistics Copilot

engine: jupyter
---

{# Title and story content #}
{# Check if story_content starts with a heading, if not add one #}
{% if story_content.strip() and not story_content.strip().startswith('#') %}
# {{ title }}

{% endif %}
{{ story_content | safe }}

{# Code cells - only output displayed, code hidden in rendered output #}
{%- if include_code_cells and python_code %}
```{python}
#| echo: false
#| fold: true
#| title: "Data Analysis Code"
{{ python_code | safe }}
```
{% endif %}
