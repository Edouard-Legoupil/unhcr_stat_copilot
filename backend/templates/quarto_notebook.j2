{# UNHCR Quarto Notebook Template #}
{# Uses Jinja2 templating for flexible document generation #}
---
title: {{ title|quote_yaml }}
author: {{ author|quote_yaml }}
date: {{ date|quote_yaml }}
format:
  html:
    embed-resources: true
    standalone: true
    {%- if use_unhcr_theme %}
    theme:
      - unhcr
      - cosmo
    css: unhcr.css
    {%- else %}
    theme: cosmo
    {%- endif %}
  pdf:
    documentclass: article
    papersize: a4
    geometry:
      - top=30mm
      - left=20mm
      - right=20mm
      - bottom=30mm
editor: visual
engine: jupyter
---

{# Main story content #}
{% if story_content.strip().startswith('#') %}
{{ story_content.strip() | escape_jinja }}
{% else %}
# {{ title }}

{# Metadata stored as HTML comments (not rendered in output) #}
{% if audience or document_type %}
<!-- Generated: {{ timestamp }} -->
{% if audience %}
<!-- Audience: {{ audience }} -->
{% endif %}
{% if document_type %}
<!-- Document Type: {{ document_type }} -->
{% endif %}

{% endif %}
{{ story_content.strip() | escape_jinja }}
{% endif %}

{% if analysis_config %}
{# Analysis config metadata stored as HTML comments (not rendered) #}
<!-- Analysis Config Tone: {{ analysis_config.get('tone', 'formal, precise, objective') }} -->
{% if analysis_config.get('length') %}
<!-- Analysis Config Length: {{ analysis_config.get('length', {}).get('wordRange', '1200-3000') }} words -->
<!-- Analysis Config Reading Time: {{ analysis_config.get('length', {}).get('readingTime', '6-15 min') }} -->
{% endif %}
<!-- Analysis Config Structure: {{ analysis_config.get('structure', []) | join(' -> ') | default("N/A") }} -->

{% endif %}

{# Code cells section (optional) - echo: false hides code in rendered output #}
{% if include_code_cells and python_code %}

```{python}
#| echo: false
{{ python_code }}
```
{% endif %}

{# Audit trail section stored as HTML comments (not rendered) #}
{% if original_query %}
<!-- Document generated by an AI assistant using the UNHCR MCP Server -->
<!-- This analysis is based on data from UNHCR and has been automatically generated -->

<!-- Important: AI-generated content may contain errors or inaccuracies -->
<!-- Verify critical figures with official UNHCR sources before distribution -->
<!-- This document does not represent official UNHCR policy or positions -->
<!-- Human review and validation is required before distribution -->

<!-- Original Query: {{ original_query|replace("`", "'") }} -->
<!-- Generated: {{ timestamp }} -->

<!-- Analysis Methodology: -->
<!-- This analysis was generated using the following tool sequence: -->
{% for tool in metadata.get('tool_sequence', []) %}
<!-- - {{ tool.tool }}: {{ 'SUCCESS' if tool.get('success', False) else 'FAILED' }} ({{ tool.get('duration_ms', 0) }}ms) -->
<!--   Purpose: {{ tool.get('result_summary', tool.get('error', 'N/A')) }} -->
{% endfor %}

<!-- Data Sources: UNHCR Population Statistics API -->
<!-- Processing Steps: Question classification -> Data retrieval -> Story generation -> Quarto compilation -->
<!-- Quality Assurance: Each tool call is validated and errors are handled gracefully -->
{% endif %}
