{# UNHCR Quarto Notebook Template #}
{# Uses Jinja2 templating for flexible document generation #}
---
title: {{ title|e }}
author: {{ author|e }}
date: {{ date|e }}
format:
  html:
    embed-resources: true
    standalone: true
    {%- if use_unhcr_theme %}
    theme:
      - unhcr
      - cosmo
    css: unhcr.css
    {%- else %}
    theme: cosmo
    {%- endif %}
  pdf:
    documentclass: article
    papersize: a4
    geometry:
      - top=30mm
      - left=20mm
      - right=20mm
      - bottom=30mm
editor: visual
engine: jupyter
---

{# Main story content #}
{% if story_content.strip().startswith('#') %}
{{ story_content.strip() | escape_jinja }}
{% else %}
# {{ title }}

{% if audience or document_type %}
**Generated**: {{ timestamp }}
{% if audience %}
**Audience**: {{ audience }}
{% endif %}
{% if document_type %}
**Document Type**: {{ document_type }}
{% endif %}

{% endif %}
{{ story_content.strip() | escape_jinja }}
{% endif %}

{% if analysis_config %}
## About This Analysis

This analysis was automatically generated using the UNHCR Statistics Copilot.

- **Tone**: {{ analysis_config.get('tone', 'formal, precise, objective') }}
{% if analysis_config.get('length') %}
- **Length**: {{ analysis_config.get('length', {}).get('wordRange', '1200-3000') }} words
- **Reading Time**: {{ analysis_config.get('length', {}).get('readingTime', '6-15 min') }}
{% endif %}
- **Structure**: {{ analysis_config.get('structure', []) | join(' -> ') | default("N/A") }}

{% endif %}

{# Code cells section (optional) #}
{% if include_code_cells and python_code %}

