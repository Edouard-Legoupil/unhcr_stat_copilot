{# UNHCR Quarto Notebook Template #}
{# Uses Jinja2 templating for flexible document generation #}
---
title: {{ title|e }}
author: {{ author|e }}
date: {{ date|e }}
format:
  html:
    embed-resources: true
    standalone: true
  {% if use_unhcr_theme %}
    theme:
      - unhcr
      - cosmo
    css: unhcr.css
  {% else %}
    theme: cosmo
  {% endif %}
  pdf:
    documentclass: article
    papersize: a4
    geometry:
      - top=30mm
      - left=20mm
      - right=20mm
      - bottom=30mm
editor: visual
engine: jupyter
---

