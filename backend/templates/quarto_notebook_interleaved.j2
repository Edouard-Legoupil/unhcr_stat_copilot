## Data Visualization

{% if has_items %}
```{python}
#| label: "Main Visualization"
#| echo: false
#| fold: false
#| fig-height: 8
#| fig-width: 12

# Generate visualization based on data structure
import pandas as pd
import matplotlib.pyplot as plt

# Extract data items
items = {{ items|to_python }}
df = pd.DataFrame(items)

# Detect time series and value columns
time_col = None
numeric_cols = []
for col in df.columns:
    col_lower = col.lower()
    if 'year' in col_lower:
        time_col = col
    elif pd.api.types.is_numeric_dtype(df[col]) and not any(skip in col_lower for skip in ['id', 'iso', 'hst', 'code']):
        numeric_cols.append(col)

# If we have a time column and numeric columns, create time series chart
if time_col and numeric_cols:
    plt.figure(figsize=(10, 6))
    for pop_type in numeric_cols:
        if pop_type != time_col:
            plt.plot(df[time_col], df[pop_type], label=pop_type.replace('_', ' ').title(), marker='o')
    plt.xlabel(time_col.replace('_', ' ').title())
    plt.ylabel('Count')
    plt.title('Population Trends Over Time')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.show()
elif numeric_cols:
    # Create bar chart for non-time-series data
    plt.figure(figsize=(10, 6))
    if len(numeric_cols) == 1:
        df.plot(kind='bar', x=df.columns[0], y=numeric_cols[0], ax=plt.gca())
    else:
        df[numeric_cols].plot(kind='bar', ax=plt.gca())
    plt.title('Population Distribution')
    plt.ylabel('Count')
    plt.xticks(rotation=45)
    plt.grid(True, alpha=0.3, axis='y')
    plt.tight_layout()
    plt.show()

print(f"Main visualization generated from {len(items)} data points")
```
