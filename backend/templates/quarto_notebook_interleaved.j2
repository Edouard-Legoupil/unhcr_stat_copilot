```{python}
#| label: "Detailed Charts"
#| echo: false
#| fold: true
import json
import pandas as pd
import matplotlib.pyplot as plt

# Visualization structure from analysis
viz_structure = {{ viz_structure|to_python }}
print("Visualization structure:", json.dumps(viz_structure, indent=2))

# Extract data for additional visualizations
{% if has_items %}
items = {{ items|to_python }}
{% elif has_list_data %}
items = {{ items|to_python }}
{% else %}
items = []
{% endif %}

{% if has_valid_data %}
df = pd.DataFrame({% if has_items %}{{ items|to_python }}{% elif has_list_data %}{{ items|to_python }}{% else %}[]{% endif %})

# Create scatter plot for correlations if we have multiple numeric columns
numeric_cols = [col for col in df.columns if pd.api.types.is_numeric_dtype(df[col])]
if len(numeric_cols) >= 2:
    plt.figure(figsize=(10, 6))
    x_col = numeric_cols[0]
    for y_col in numeric_cols[1:]:
        if y_col != x_col:
            plt.scatter(df[x_col], df[y_col], label=y_col.replace('_', ' ').title(), alpha=0.6)
    plt.xlabel(x_col.replace('_', ' ').title())
    plt.ylabel('Value')
    plt.title('Correlation Analysis')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.show()

# Create stacked bar chart for breakdown by category
if len(numeric_cols) > 1:
    plt.figure(figsize=(12, 6))
    ax = df[numeric_cols].plot(kind='bar', stacked=True, ax=plt.gca())
    plt.title('Population Breakdown by Category')
    plt.ylabel('Count')
    plt.xticks(rotation=45)
    plt.legend(title='Category')
    plt.grid(True, alpha=0.3, axis='y')
    plt.tight_layout()
    plt.show()
{% endif %}
