# Docker ignore file for UNHCR Statistics Copilot

# Ignore virtual environments
**/.venv
**/venv
**/env
**/.env

# Ignore node modules (except frontend/node_modules)
**/node_modules
!frontend/node_modules

# Ignore build directories (except frontend/dist)
**/dist
!frontend/dist
**/build
**/__pycache__

# Ignore IDE files
**/.vscode
**/.idea
**/.history

# Ignore git files
**/.git
**/.gitignore
!.gitkeep

# Ignore logs and data
**/logs
**/*.log
**/data

# Ignore test files
**/test
**/*test*.py

# Ignore Python bytecode
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore DS_Store files
**/.DS_Store

# Ignore coverage files
**/coverage
**/.coverage

# Ignore local development files
**/local_settings.py
**/settings_local.py

# Ignore documentation build
**/docs/_build

# Ignore uploads and generated files
**/uploads
**/generated
**/static
!data/vector_store/unhcr_reports.duckdb

# Ignore SSH keys and sensitive files
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519
**/*.pem

# Ignore Docker-related files (but keep Dockerfile itself)
.dockerignore
docker-compose*.yml

# Allow frontend source files (needed for build)
!frontend/src
!frontend/public